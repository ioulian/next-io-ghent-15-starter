{
  "name": "next-io-ghent-15-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "// general": "echo 'General stuff'",
    "prepare": "husky",
    "postinstall": "husky",
    "// project": "echo 'Next.js specific stuff'",
    "dev": "pnpm svg-sprite:build && next typegen && next dev --experimental-https",
    "analyze": "pnpm svg-sprite:build && next typegen && cross-env ANALYZE=true pnpm build",
    "build": "pnpm check:build-prerequisites && pnpm svg-sprite:build && next typegen && next build",
    "start": "next start",
    "// code": "echo 'Code checks, linters and formatters'",
    "check:precommit": "pnpm format:code && pnpm check:all && pnpm test:all",
    "check:all": "pnpm check:lint && pnpm check:types && pnpm check:translations",
    "check:code": "knip --config knip.config.ts",
    "check:translations": "i18n-check -s en-GB --locales messages/",
    "check:build-prerequisites": "tsx scripts/check-build-prerequisites.ts",
    "check:lint": "eslint --fix .",
    "check:types": "pnpm svg-sprite:build && next typegen && tsc --noemit --extendedDiagnostics",
    "check:types:go": "pnpm svg-sprite:build && tsgo --noemit --extendedDiagnostics",
    "format:code": "prettier --write .",
    "// storybook": "echo 'Storybook stuff'",
    "storybook": "pnpm svg-sprite:build && storybook dev -p 6006",
    "build-storybook": "pnpm svg-sprite:build && storybook build",
    "// tests": "echo 'Tests'",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:storybook": "pnpm svg-sprite:build && test-storybook",
    "test": "vitest --watch false --project=default",
    "test:project-storybook": "vitest --watch false --project=storybook",
    "test:watch": "vitest --watch --project=default",
    "test:e2e": "playwright test",
    "// SVG Sprites": "echo 'SVG Sprites'",
    "svg-sprite:build": "tsx scripts/svg-sprite/index.ts && prettier --write ./src/components/atoms/svg-sprite/SvgSprite.generated.ts",
    "test:browser": "vitest"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.16.0"
  },
  "dependencies": {
    "@bprogress/next": "3.2.12",
    "@floating-ui/react": "0.27.19",
    "@hookform/resolvers": "5.2.2",
    "@t3-oss/env-nextjs": "0.13.10",
    "@tabler/icons": "3.40.0",
    "@tanstack/react-table": "8.21.3",
    "@tiptap/extension-subscript": "3.20.5",
    "@tiptap/extension-superscript": "3.20.5",
    "@tiptap/pm": "3.20.5",
    "@tiptap/react": "3.20.5",
    "@tiptap/starter-kit": "3.20.5",
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "clsx": "2.1.1",
    "colorjs.io": "0.6.1",
    "easing-coordinates": "2.0.2",
    "es-toolkit": "1.45.1",
    "flattie": "1.1.1",
    "next": "16.2.1",
    "next-intl": "4.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-paginate": "8.3.0",
    "react-tabs": "6.1.0",
    "react-toastify": "11.0.5",
    "react-use": "17.6.0",
    "swiper": "12.1.2",
    "tailwind-variants": "3.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.2",
    "@csstools/postcss-global-data": "4.0.0",
    "@faker-js/faker": "10.3.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@lingual/i18n-check": "0.9.3",
    "@next/bundle-analyzer": "16.2.1",
    "@next/env": "16.2.1",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-links": "10.3.3",
    "@storybook/addon-onboarding": "10.3.3",
    "@storybook/addon-vitest": "10.3.3",
    "@storybook/nextjs-vite": "10.3.3",
    "@storybook/test-runner": "0.24.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/svg-sprite": "0.0.39",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/browser-playwright": "4.1.1",
    "@vitest/coverage-v8": "4.1.1",
    "cross-env": "10.1.0",
    "cssnano": "7.1.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-baseline-js": "0.6.1",
    "eslint-plugin-depend": "1.5.0",
    "eslint-plugin-i18next": "6.1.3",
    "eslint-plugin-jsx-a11y-x": "0.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.9.2",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-storybook": "10.3.3",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "knip": "6.0.5",
    "lint-staged": "16.4.0",
    "playwright": "1.58.2",
    "postcss": "8.5.8",
    "postcss-custom-media": "12.0.1",
    "postcss-import": "16.1.1",
    "postcss-nesting": "14.0.0",
    "postcss-preset-env": "11.2.0",
    "prettier": "3.8.1",
    "react-docgen-typescript": "2.4.0",
    "react-scan": "0.5.3",
    "storybook": "10.3.3",
    "storybook-addon-test-codegen": "3.0.1",
    "storybook-next-intl": "10.1.1",
    "svg-sprite": "2.0.4",
    "svgo-loader": "4.0.0",
    "ts-deepmerge": "7.0.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.1"
  },
  "pnpm": {
    "patchedDependencies": {
      "react-paginate": "patches/react-paginate.patch"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@swc/core",
      "core-js-pure",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2"
    }
  }
}
